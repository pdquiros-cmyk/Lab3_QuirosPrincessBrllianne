    <style>
        /* Keyframe for Fade In */
        @keyframes fadeInUp {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* Keyframe for modern Scrolling Text */
        @keyframes scrollText {
            0% { transform: translateX(100%); }
            100% { transform: translateX(-100%); }
        }

        body {
            font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
            color: #333;
            margin: 0;
            padding: 40px 20px;
            min-height: 100vh;
        }

        .container {
            max-width: 850px;
            margin: auto;
            background: #ffffff; 
            padding: 40px;
            border-top: 8px solid #0056b3; 
            border-radius: 12px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            animation: fadeInUp 0.8s ease-out; /* Entrance Animation */
            transition: transform 0.3s ease;
        }

        .container:hover {
            transform: translateY(-5px); /* Subtle lift on hover */
        }

        /* Modern Scrolling Header */
        .marquee-wrapper {
            background-color: #0056b3; 
            color: white;
            padding: 12px;
            border-radius: 6px;
            margin-bottom: 25px;
            overflow: hidden;
            position: relative;
            white-space: nowrap;
        }

        .marquee-content {
            display: inline-block;
            padding-left: 100%;
            animation: scrollText 15s linear infinite;
            font-weight: bold;
            text-transform: uppercase;
            letter-spacing: 2px;
        }

        .group-photo {
            display: block;
            margin: 20px auto;
            border: 4px solid #f8f9fa;
            border-radius: 8px;
            box-shadow: 0 4px 10px rgba(0,0,0,0.1);
            max-width: 100%;
            height: auto;
            transition: filter 0.3s ease;
        }

        .group-photo:hover {
            filter: brightness(1.05);
        }

        h1 { 
            color: #003366; 
            font-size: 2.2rem; 
            margin-bottom: 10px;
        }

        h2 { 
            color: #0056b3; 
            font-size: 0.9rem; 
            text-transform: uppercase; 
            letter-spacing: 2px;
            border-bottom: 2px solid #e1e8ed;
            padding-bottom: 8px;
            margin-top: 40px;
        }

        mark { 
            background-color: #d1ecf1; 
            color: #0c5460; 
            padding: 2px 8px; 
            border-radius: 3px;
        }
        
        hr { 
            border: 0; 
            height: 1px; 
            background: linear-gradient(to right, #e1e8ed, transparent); 
            margin: 40px 0; 
        }
        
        b { color: #0056b3; } 

        p { line-height: 1.6; font-size: 1.1rem; }

    </style>
</head>
